# ===== AudioFlow Docker 部署环境变量 =====
# 复制为 .env 后按需修改：
# cp .env.example .env

# Web UI 对外访问端口
WEB_PORT=8082

# 宿主机持久化目录
# 默认使用项目内相对路径，NAS 部署时可改成 /vol1/... 等绝对路径。
AUDIOFLOW_DATA_DIR=./data
AUDIOFLOW_CONFIG_DIR=./config
AUDIOFLOW_LOG_DIR=./logs
AUDIOFLOW_DOWNLOAD_DIR=./downloads

# 时区
TZ=Asia/Shanghai

# 反向代理时的外部访问地址，可留空
# PUBLIC_BASE_URL=https://audioflow.example.com
PUBLIC_BASE_URL=

# 前端 API 基础路径，默认走同源 /api
VITE_API_BASE_URL=/api

# 首次启动默认 Web 登录账号
# 登录后可在系统设置中修改密码，修改后会写入 CONFIG_DIR/auth.json。
AUDIOFLOW_DEFAULT_USERNAME=admin
AUDIOFLOW_DEFAULT_PASSWORD=admin

# 可选：设置后会加密保存 config/cookies.json 中的 Cookie。
# 请妥善保存该值，丢失后已加密 Cookie 无法解密。
AUDIOFLOW_COOKIE_SECRET=

# 安全开关：默认禁止直接把任意 url 传给 /api/proxy/audio。
# 正常试听会使用服务端签发的短期 token，不需要开启。
AUDIOFLOW_ALLOW_RAW_AUDIO_PROXY=false
